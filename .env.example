# Private key from Magic Link (hex, 0x prefix is fine)
# Find it: Magic Link dashboard -> your wallet -> export private key
PRIVATE_KEY=0xYourPrivateKeyHere

# Funder = your Polymarket PROXY WALLET address (NOT the signer address)
# This is the address that holds your USDC and positions.
# Find it: Polymarket -> Profile -> Wallet/Deposit -> the Polygon address shown
POLY_FUNDER=0xYourProxyWalletAddress

# Signature type: 1 = Magic Link / email login
# (0=EOA for MetaMask/hardware, 2=GNOSIS_SAFE for browser embedded wallet)
SIGNATURE_TYPE=1

# API credentials — leave blank on first run, test_order.py will derive
# them and print them out. Paste them here to skip derivation next time.
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# Polygon RPC URL for on-chain CTF redemption (optional, defaults to https://polygon-rpc.com)
# POLYGON_RPC=https://polygon-rpc.com
